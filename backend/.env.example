POSTGRES_DB=supporthub
POSTGRES_USER=supporthub
POSTGRES_PASSWORD=supporthub
POSTGRES_HOST=db
POSTGRES_PORT=5432

DJANGO_SECRET_KEY=django-insecure-change-me
DJANGO_DEBUG=True
DJANGO_LANGUAGE_CODE=pt-br
DJANGO_TIME_ZONE=America/Sao_Paulo

# fila/broker do Celery (Redis)
REDIS_URL=redis://localhost:6379/0

# envio de email transacional (Brevo). Se qualquer um estiver vazio,
# o email so' e' impresso no console (nao falha, so' nao envia de verdade)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# senha usada pelo comando `seed` para os usuarios criados
# obrigatoria quando DJANGO_DEBUG=False
SEED_PASSWORD=change-me

# controlam o entrypoint.sh do container (migrate/seed automaticos)
# em dev via compose.yaml ficam "false"; em producao, deixe sem definir
RUN_MIGRATIONS=false
RUN_SEED=false

# origens permitidas no CORS (separadas por virgula, sem espaco)
# se a chave existir vazia aqui, NENHUMA origem e' permitida - remova
# a linha (ou comente) para usar o default de dev do settings.py
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000